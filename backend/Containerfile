# Build from repository root:
#   podman build -f backend/Containerfile -t marketing-intern:latest .

FROM docker.io/library/node:20-alpine AS fe
WORKDIR /build
COPY frontend/package.json ./
RUN npm install
COPY frontend .
RUN npm run build

FROM registry.redhat.io/ubi9/python-311:latest

WORKDIR /app

COPY backend/app/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/app/main.py .
COPY backend/app/k8s_pi_job.py .
COPY --from=fe /build/dist ./frontend/dist
COPY skills/marketing-intern ./skills/marketing-intern

USER root
RUN chgrp -R 0 /app && chmod -R g=u /app

USER 1001

EXPOSE 8080

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]
